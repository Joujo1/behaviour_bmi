// ---------------------------------------------------------------------------
// Playback state — written by trigger ISR, read by timer ISR.
// Cortex-M4 16-bit aligned loads/stores are atomic → no mutex needed.
// CLICK_LEN or greater means idle (DAC outputs silence).
// ---------------------------------------------------------------------------
volatile uint16_t pos_left  = CLICK_LEN;
volatile uint16_t pos_right = CLICK_LEN;

// ---------------------------------------------------------------------------
// Trigger ISRs — reset playback position on RISING edge
// ---------------------------------------------------------------------------
void onLeftTrigger()  { pos_left  = 0; }
void onRightTrigger() { pos_right = 0; }

// ---------------------------------------------------------------------------
// TC3 timer ISR — fires at 192 kHz (120 MHz / 625)
// Outputs one 12-bit DAC sample per channel per period.
// ---------------------------------------------------------------------------
void TC3_Handler() {
    TC3->COUNT16.INTFLAG.bit.MC0 = 1;  // clear Match/Compare 0 flag

    uint16_t pl = pos_left;
    uint16_t pr = pos_right;

    // SAMD51: must wait for previous conversion to finish before writing DATA[n].
    // At 192 kHz the DAC is nearly always ready; the loop rarely iterates.
    while (DAC->SYNCBUSY.bit.DATA0);
#ifdef SQUARE_PULSE_VALIDATION
    DAC->DATA[0].reg = (pl < CLICK_LEN) ? 4095 : 2048;
#else
    DAC->DATA[0].reg = (pl < CLICK_LEN) ? CLICK_WAV[pl] : 2048;
#endif
    while (DAC->SYNCBUSY.bit.DATA1);
#ifdef SQUARE_PULSE_VALIDATION
    DAC->DATA[1].reg = (pr < CLICK_LEN) ? 4095 : 2048;
#else
    DAC->DATA[1].reg = (pr < CLICK_LEN) ? CLICK_WAV[pr] : 2048;
#endif

    if (pl < CLICK_LEN) pos_left  = pl + 1;
    if (pr < CLICK_LEN) pos_right = pr + 1;
}

// ---------------------------------------------------------------------------
// TC3 setup — 16-bit Match-Frequency mode, no prescaler, period = 624
// GCLK0 = 120 MHz → 120 000 000 / 625 = 192 000 Hz
// ---------------------------------------------------------------------------
static void setup_tc3_192kHz() {
    // Open the APB peripheral bus clock for TC3.  GCLK routing alone is not
    // enough on SAMD51 — the MCLK gate must also be set.  This is idempotent
    // if the Arduino core already enabled it (e.g. for PWM on this pin).
    MCLK->APBBMASK.reg |= MCLK_APBBMASK_TC3;

    // Route GCLK0 (120 MHz) to TC3 (SAMD51 uses per-peripheral PCHCTRL with TC3_GCLK_ID)
    GCLK->PCHCTRL[TC3_GCLK_ID].reg = GCLK_PCHCTRL_GEN_GCLK0 | GCLK_PCHCTRL_CHEN;
    while (!GCLK->PCHCTRL[TC3_GCLK_ID].bit.CHEN);

    // Software reset
    TC3->COUNT16.CTRLA.bit.SWRST = 1;
    while (TC3->COUNT16.SYNCBUSY.bit.SWRST);

    // 16-bit mode, no prescaler (SAMD51: WAVEGEN moved to separate WAVE register)
    TC3->COUNT16.CTRLA.reg = TC_CTRLA_MODE_COUNT16 | TC_CTRLA_PRESCALER_DIV1;
    TC3->COUNT16.WAVE.reg  = TC_WAVE_WAVEGEN_MFRQ;  // counter resets to 0 at CC[0]
    TC3->COUNT16.CC[0].reg = 624;   // period = 625 counts = 192 kHz
    while (TC3->COUNT16.SYNCBUSY.bit.CC0);

    // Enable Match/Compare 0 interrupt at highest hardware priority
    TC3->COUNT16.INTENSET.bit.MC0 = 1;
    NVIC_SetPriority(TC3_IRQn, 0);
    NVIC_EnableIRQ(TC3_IRQn);

    // Enable the timer
    TC3->COUNT16.CTRLA.bit.ENABLE = 1;
    while (TC3->COUNT16.SYNCBUSY.bit.ENABLE);
}

// ---------------------------------------------------------------------------
void setup() {
    // Enable both 12-bit DAC channels and set them to mid-rail (silence).
    // analogWrite initialises the DAC peripheral; subsequent writes in the
    // ISR go directly to DAC->DATA[n].reg for lowest latency.
    analogWriteResolution(12);
    analogWrite(A0, 2048);
    analogWrite(A1, 2048);

    // Force VDDANA (3.3 V) as DAC reference — analogWrite() may leave it on
    // the internal bandgap (~1.2 V), which would cap peak output at ~1.2 V.
    while (DAC->SYNCBUSY.bit.SWRST || DAC->SYNCBUSY.bit.ENABLE);
    DAC->CTRLB.bit.REFSEL = 0x02;  // VDDANA on SAMD51

    setup_tc3_192kHz();

    pinMode(TRIGGER_LEFT,  INPUT);
    pinMode(TRIGGER_RIGHT, INPUT);
    attachInterrupt(digitalPinToInterrupt(TRIGGER_LEFT),  onLeftTrigger,  RISING);
    attachInterrupt(digitalPinToInterrupt(TRIGGER_RIGHT), onRightTrigger, RISING);
}

void loop() {
    // Everything is interrupt-driven — nothing to do here.
}
