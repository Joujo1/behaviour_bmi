// click_player.ino — ItsyBitsy M4 Express (SAMD51)
//
// Dedicated click-audio player for the behaviour_bmi rig.
//
// The Raspberry Pi is the sole scheduler: it busy-waits to each Poisson
// click time and fires a 100 µs TTL HIGH pulse on BCM10 (left) or BCM9
// (right).  A RISING-edge interrupt here resets the DAC playback position
// to zero; the TC3 timer ISR at 192 kHz clocks out one 12-bit sample per
// channel each period.
//
// Pinout:
//   D9  — left  trigger input  (Pi BCM7 / physical 26)
//   D10 — right trigger input  (Pi BCM1 / physical 28)
//   A0  — left  DAC output  (through 10 µF DC-blocking cap to amplifier)
//   A1  — right DAC output  (through 10 µF DC-blocking cap to amplifier)
//
// Waveform: 4 tones (2/4/8/16 kHz), 40 dB attenuation each, cosine²
// fade-in and fade-out (2 ms each), peak-normalised, 576 samples @ 192 kHz.

#define TRIGGER_LEFT  9
#define TRIGGER_RIGHT 10

// ---------------------------------------------------------------------------
// Uncomment for timing-validation builds only — outputs a 3 ms square pulse
// on both DAC channels instead of the production waveform  so the rising edge
// is threshold-detectable on an oscilloscope.  Leave commented for production.
// ---------------------------------------------------------------------------
//#define SQUARE_PULSE_VALIDATION

